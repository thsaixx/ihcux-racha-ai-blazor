## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
[Dd]ebug/x64/
[Dd]ebug/x86/
[Rr]elease/x64/
[Rr]elease/x86/
bin/
obj/
out/
artifacts/
.artifacts/
[Oo]ut/
[Oo]bj/
bld/

# Visual Studio
.vs/
Generated\ Files/

# Logs and temp files
*.log
*.tlog
*.pidb
*.svclog
dotnet-run*.log
dotnet-run.pid

# Packages and dependencies
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
node_modules/

# Publish and installers
publish/
*.publish.xml
*.azurePubxml
*.pubxml
*.publishproj
PublishScripts/
*.cab
*.msi
*.msix
*.msm
*.msp

# Coverage and reports
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml
*.trx
TestResult.xml
nunit-*.xml
BenchmarkDotNet.Artifacts/
MSBuild_Logs/
*.binlog

# Python
**/__pycache__/
*.pyc

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
**/.localhistory/
*.vsix

# Project-specific test artifacts
playwright-*.png
